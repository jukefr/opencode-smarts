{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "external_directory": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "DROP TABLE*": "deny",
      "DROP DATABASE*": "deny"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": "engram",
      "args": ["mcp"],
      "enabled": true
    }
  }
}
